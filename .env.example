# Copy this file to .env.local for development.
# In production (Fly), set these as build-time secrets:
#   fly secrets set VITE_CRM_API_URL=... VITE_PROVIDER_FORM_API_KEY=...
# Vite inlines VITE_-prefixed vars at build time, so they end up in the
# bundle. Treat the API key as a low-trust shared secret — it's stored
# in env, not in git, but it ships to the client.

# Base URL of the TFC CRM API (no trailing slash).
# Production:  https://tfc-crm-2-0.fly.dev
VITE_CRM_API_URL=

# Shared secret sent in the X-Provider-Form-Key header.
# Must match the PROVIDER_FORM_API_KEY env var on the CRM server.
VITE_PROVIDER_FORM_API_KEY=
